# F-13 FIX: Normaliza line endings para LF em todos os arquivos de texto.
# Evita inconsistências entre ambientes Windows (CRLF) e Unix (LF).

* text=auto eol=lf

# PHP e web files: sempre LF
*.php    text eol=lf
*.js     text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.sql    text eol=lf
*.csv    text eol=lf
*.txt    text eol=lf
*.env    text eol=lf

# Configuração
.htaccess      text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf

# Binários: não modificar
*.ico    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.woff   binary
*.woff2  binary
